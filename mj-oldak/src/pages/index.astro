<script is:inline>

const ROTATE_MS = 8000;
const VER = '?v=4';
let photos = [], idx = 0, timer = null, progressTimer = null, paused = false;

async function loadPhotos() {
  const r = await fetch('/photos.json' + VER);
  photos = await r.json();
  // console.log('photos.json loaded:', photos.length);
  photos.forEach(p => { const im = new Image(); im.src = p.src + VER; });
  apply(0);
  start();
}

function apply(i) {
  idx = i;
  const p = photos[idx];
  // console.log('apply →', p.name, p.accent);
  const hero = document.getElementById('hero');
  hero.style.backgroundImage = `url('${p.src}${VER}')`;
  hero.classList.toggle('low-res', !!p.lowRes);
  document.documentElement.style.setProperty('--accent', p.accent);
  document.documentElement.style.setProperty('--dark', p.dark);
  // Subtle photo behind the "Pomagamy" section uses a different image — rotate it too
  const helpPhoto = document.getElementById('helpPhoto');
  if (helpPhoto) {
    helpPhoto.style.backgroundImage = `url('${p.src}${VER}')`;
  }
  document.getElementById('hudName').textContent = p.name.replace('IMG_','');
  document.getElementById('hudHex').textContent = p.accent;
  document.getElementById('hudSwatch').style.background = p.accent;
  resetProgress();
}

function next() { apply((idx + 1) % photos.length); restart(); }
function prev() { apply((idx - 1 + photos.length) % photos.length); restart(); }
function start() {
  // Auto-rotate disabled when user scrolls — sections drive theme
