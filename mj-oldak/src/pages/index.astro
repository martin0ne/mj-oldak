---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavbarPersonal from '../components/personal/NavbarPersonal.jsx';
import HeroPersonal from '../components/personal/HeroPersonal.jsx';
import About from '../components/personal/About.astro';
import Work from '../components/personal/Work.astro';
import Skills from '../components/personal/Skills.astro';
import Writing from '../components/personal/Writing.astro';
import ContactPersonal from '../components/personal/ContactPersonal.jsx';

const title = 'Marcin J. Ołdak — AI & Automation Consultant';
const description = 'AI & automation consultant — autonomous AI agents, n8n workflow automation, LLM-backed apps from PoC to production. 4 production-ready products + interactive demos you can try in the browser.';
---
<BaseLayout title={title} description={description} lang="en" includeOrganizationSchema={false}>
  <NavbarPersonal client:load />
  <HeroPersonal client:load />
  <About />
  <Work />
  <Skills />
  <Writing />
  <ContactPersonal client:visible />
</BaseLayout>
