---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.jsx';
import NewsletterSignup from '../components/NewsletterSignup.jsx';
import RelatedArticles from '../components/RelatedArticles.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  article: CollectionEntry<'articles'>;
  related?: CollectionEntry<'articles'>[];
}

const { article, related = [] } = Astro.props;
const { title, excerpt, publishedAt, updatedAt, author, category, tags, cover, coverAlt, readingTime, metaTitle, metaDescription, keywords } = article.data;

const publishedISO = publishedAt.toISOString();
const updatedISO = updatedAt?.toISOString();
const dateFormatted = new Intl.DateTimeFormat('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' }).format(publishedAt);

const siteURL = 'https://mj-oldak.com';
const articleURL = `${siteURL}/artykuly/${article.id.replace(/\.md$/, '')}/`;
const ogImageURL = cover ? (cover.startsWith('http') ? cover : `${siteURL}${cover}`) : `${siteURL}/og-image.jpg`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: metaDescription ?? excerpt,
  image: ogImageURL,
  datePublished: publishedISO,
  dateModified: updatedISO ?? publishedISO,
  author: { '@type': 'Person', name: author, url: 'https://mj-oldak.com/' },
  publisher: {
    '@type': 'Organization',
    name: 'MJ.OLDAK',
    logo: { '@type': 'ImageObject', url: `${siteURL}/favicon.svg` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleURL },
  keywords: (keywords ?? tags).join(', '),
  articleSection: category,
};

const breadcrumbsLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Strona główna', item: siteURL + '/' },
    { '@type': 'ListItem', position: 2, name: 'Artykuły', item: siteURL + '/artykuly/' },
    { '@type': 'ListItem', position: 3, name: title, item: articleURL },
  ],
};
---
<BaseLayout
  title={metaTitle ?? `${title} — MJ.OLDAK`}
  description={metaDescription ?? excerpt}
  canonical={articleURL}
  ogImage={cover ?? '/og-image.jpg'}
  ogType="article"
  publishedTime={publishedISO}
  author={author}
  tags={tags as unknown as string[]}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbsLd)} />

  <div class="noise-overlay"></div>
  <Navbar client:load />

  <article class="pt-32 pb-20">
    {/* Hero */}
    <header class="max-w-4xl mx-auto px-6 md:px-12 mb-12">
      <a href="/artykuly/" class="inline-flex items-center gap-2 font-mono text-[10px] uppercase tracking-widest text-dark/60 hover:text-accent transition no-underline mb-8">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Powrót do artykułów
      </a>
      <div class="flex items-center gap-3 mb-6">
        <span class="font-mono text-[10px] uppercase tracking-widest px-3 py-1 rounded-full bg-accent/10 text-accent border border-accent/20">{category}</span>
        <span class="font-mono text-[10px] uppercase tracking-widest text-dark/40">{dateFormatted}</span>
        {readingTime && <span class="font-mono text-[10px] uppercase tracking-widest text-dark/40">· {readingTime} min czytania</span>}
      </div>
      <h1 class="font-sans font-bold text-4xl md:text-6xl uppercase tracking-tight text-dark mb-6 leading-tight">
        {title}
      </h1>
      <p class="font-mono text-base md:text-lg text-dark/70 leading-relaxed max-w-3xl">
        {excerpt}
      </p>
      <div class="mt-6 flex items-center gap-3 text-sm font-mono text-dark/50">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        <span>{author}</span>
      </div>
    </header>

    {cover && (
      <div class="max-w-5xl mx-auto px-6 md:px-12 mb-12">
        <img src={cover} alt={coverAlt ?? title} class="w-full h-auto rounded-[2rem] border border-dark/10 shadow-lg" loading="eager" />
      </div>
    )}

    {/* Body */}
    <div class="max-w-3xl mx-auto px-6 md:px-12 article-prose">
      <slot />
    </div>

    {/* Tags */}
    <div class="max-w-3xl mx-auto px-6 md:px-12 mt-12 pt-8 border-t border-dark/10">
      <p class="font-mono text-[10px] uppercase tracking-widest text-dark/40 mb-4">Tagi</p>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <a href={`/artykuly/tag/${tag}/`} class="font-mono text-xs uppercase tracking-widest px-3 py-1.5 rounded-full bg-dark/[0.05] hover:bg-accent hover:text-primary border border-dark/10 text-dark/70 transition no-underline">
            #{tag}
          </a>
        ))}
      </div>
    </div>

    {/* Newsletter */}
    <div class="max-w-3xl mx-auto px-6 md:px-12 mt-16">
      <NewsletterSignup client:visible />
    </div>

    {/* Related */}
    {related.length > 0 && (
      <div class="max-w-5xl mx-auto px-6 md:px-12 mt-20 pt-12 border-t border-dark/10">
        <h2 class="font-sans font-bold text-2xl md:text-3xl uppercase tracking-tight text-dark mb-8">
          Powiązane <span class="font-serif italic font-normal text-accent">artykuły.</span>
        </h2>
        <RelatedArticles articles={related} />
      </div>
    )}
  </article>

  <Footer client:visible />
</BaseLayout>

<style is:global>
  .article-prose {
    font-family: 'AtSymbolFix', 'Space Mono', monospace;
    color: #111;
    line-height: 1.75;
  }
  .article-prose > * + * { margin-top: 1.25rem; }
  .article-prose h2 {
    font-family: 'AtSymbolFix', 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1.875rem;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    border-left: 4px solid #E63B2E;
    padding-left: 1rem;
  }
  .article-prose h3 {
    font-family: 'AtSymbolFix', 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1.375rem;
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .article-prose p { font-size: 1rem; }
  .article-prose ul, .article-prose ol { padding-left: 1.5rem; font-size: 1rem; }
  .article-prose li { margin-bottom: 0.5rem; }
  .article-prose ul li { list-style: none; position: relative; }
  .article-prose ul li::before {
    content: '▸';
    color: #E63B2E;
    position: absolute;
    left: -1.25rem;
    font-weight: bold;
  }
  .article-prose ol { list-style: decimal; }
  .article-prose blockquote {
    border-left: 4px solid #E63B2E;
    padding: 1rem 1.5rem;
    background: rgba(17,17,17,0.04);
    border-radius: 0 1rem 1rem 0;
    font-style: italic;
    font-family: 'DM Serif Display', serif;
    font-size: 1.25rem;
    color: #111;
  }
  .article-prose code {
    font-family: 'AtSymbolFix', 'Space Mono', monospace;
    background: rgba(17,17,17,0.08);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }
  .article-prose pre {
    background: #111;
    color: #E8E4DD;
    padding: 1.5rem;
    border-radius: 1rem;
    overflow-x: auto;
    font-family: 'Space Mono', monospace;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .article-prose pre code { background: transparent; padding: 0; }
  .article-prose a {
    color: #E63B2E;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }
  .article-prose a:hover { background: rgba(230,59,46,0.08); }
  .article-prose strong { color: #111; font-weight: 700; }
  .article-prose img { border-radius: 1rem; border: 1px solid rgba(17,17,17,0.1); }
  .article-prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin: 1.5rem 0;
  }
  .article-prose th {
    background: rgba(17,17,17,0.08);
    font-family: 'AtSymbolFix', 'Space Grotesk', sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 2px solid #E63B2E;
  }
  .article-prose td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(17,17,17,0.08);
  }
  .article-prose hr {
    border: 0;
    border-top: 1px solid rgba(17,17,17,0.1);
    margin: 3rem 0;
  }
</style>
