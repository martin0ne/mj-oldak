---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'MJ.OLDAK — Agenci AI dla biur rachunkowych w Polsce | OCR faktur, KSeF, automatyzacja';
const description = 'Buduje AI agentów dla polskich biur rachunkowych: OCR faktur w 8 sekund, klasyfikacja maili klientów, kalendarz podatkowy 2026 (VAT, JPK, KSeF), raporty miesięczne PDF. Pilot za darmo. Stack: Claude API + Azure Document Intelligence + Astro.';
---
<BaseLayout title={title} description={description} ogImage="/social/og-image.jpg" includeOrganizationSchema={true}>
<style is:global>

  :root {
    --bg: #E4DBCD;
    --primary: #CAC2AE;
    --accent: #4F8EBA;
    --dark: #0D1B32;
    --sunset: #C87E3B;
    --transition-dur: 1.5s;

    /* Cloud Design tokens (sekcje 02 + 03 editorial v1) */
    --font-display: 'Manrope', system-ui, sans-serif;
    --font-italic: 'Fraunces', Georgia, serif;
    --font-body: 'Inter', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    --cd-nav-reserve: 88px;
    --cd-section-h: calc(100vh - var(--cd-nav-reserve));
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; /* smooth tylko dla nav clicks, brak snap */ }
  body {
    background: var(--dark); color: var(--primary);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 16px; line-height: 1.65;
    transition: background var(--transition-dur) ease, color var(--transition-dur) ease;
    min-height: 100vh;
  }
  /* Każda sekcja minimum 100vh, content może rosnąć naturalnie */
  .hero, section.story, .contact {
    min-height: 100vh;
  }
  a { color: inherit; text-decoration: none; }

  /* ── Shader background layer ──
     RULE:
     - Hero ALWAYS keeps photo carousel as primary (toggle switches Hero only)
     - Sekcje niżej (Pomagamy / Produkty / Proces / Pilot / Artykuły / Kontakt)
       MAJĄ shader ambient ZAWSZE widoczny (subtle), niezależnie od toggle
  */
  .shader-bg {
    position: absolute; inset: 0; z-index: 0;
    width: 100%; height: 100%;
    border: 0; pointer-events: none;
    transition: opacity 0.6s ease;
  }
  /* Hero: shader hidden by default (photo wygrywa), tylko w shader-mode visible */
  .hero .shader-bg { opacity: 0; pointer-events: none; }
  body.shader-mode .hero .shader-bg { opacity: 1; pointer-events: auto; }
  body.shader-mode .hero { background-image: none !important; }
  body.shader-mode .hero::after { opacity: 0.4; }
  /* Sections niżej: shader visible jako ambient ZAWSZE, cursor reactions OFF default (fix hover-induced lag — shader iframes mają mousemove handlers + pointer-events:auto = freeze-resume jank gdy mouse hover na child elements bento/stations) */
  section.story.light .shader-bg { opacity: 0.32; pointer-events: none; }
  section.story.dark .shader-bg, .pilot-section .shader-bg, .contact .shader-bg { opacity: 0.7; pointer-events: none; }
  /* W shader-mode section ambient się boostuje + cursor reactivity ON (świadome user opt-in via SHADER toggle pill) */
  body.shader-mode section.story.light .shader-bg { opacity: 0.85; pointer-events: auto; }
  body.shader-mode section.story.dark .shader-bg,
  body.shader-mode .pilot-section .shader-bg,
  body.shader-mode .contact .shader-bg { opacity: 1; pointer-events: auto; }

  /* SCRIM behind content — SUBTLE, only contrast booster, NIE bleach */
  section.story::before, .contact::before {
    content: ''; position: absolute; inset: 0; z-index: 1;
    pointer-events: none;
    transition: background var(--transition-dur) ease;
  }
  /* Dark sections: subtle dark vignette */
  section.story.dark::before, .pilot-section::before, .contact::before {
    background: radial-gradient(ellipse at 50% 40%,
      color-mix(in srgb, var(--dark) 25%, transparent) 0%,
      color-mix(in srgb, var(--dark) 10%, transparent) 60%,
      transparent 100%);
  }
  /* Light sections: subtle light vignette */
  section.story.light::before {
    background: radial-gradient(ellipse at 50% 40%,
      color-mix(in srgb, var(--bg) 30%, transparent) 0%,
      color-mix(in srgb, var(--bg) 12%, transparent) 60%,
      transparent 100%);
  }
  /* Text-shadow — minimalna 2-3px halo, bez bleached look */
  section.story.dark, .pilot-section, .contact { text-shadow: 0 1px 3px rgba(13,27,50,0.5); }
  section.story.light { text-shadow: 0 1px 2px rgba(228,219,205,0.45); }
  /* CTAs / buttons / badges — no shadow (have own bg) */
  .cta, .cta-nav, .b-badge, .station .num, .station .label, .station .desc, .ocr-fields .key, .ocr-fields .val { text-shadow: none; }
  /* H1/H2 boost weight + contrast w shader sections */
  section.story h2.section-title, .hero h1 { font-weight: 800; }

  /* Eyebrow + lede readability boost na shader bg */
  section.story.dark .eyebrow, .pilot-section .eyebrow, .contact .eyebrow {
    opacity: 0.95 !important; color: var(--accent);
    text-shadow: 0 1px 4px rgba(13,27,50,0.7);
  }
  section.story.dark .lede, .pilot-section .lede, .contact .lede {
    opacity: 1 !important; color: #fff;
    text-shadow: 0 1px 6px rgba(13,27,50,0.65);
  }
  section.story.light .eyebrow {
    opacity: 0.95 !important; color: var(--accent);
    text-shadow: 0 1px 3px rgba(228,219,205,0.6);
  }
  section.story.light .lede {
    opacity: 1 !important; color: var(--dark);
    text-shadow: 0 1px 4px rgba(228,219,205,0.55);
  }

  /* === Cursor spotlight back, BEZ mix-blend-mode (gladkie radial overlay) === */
  section.story::after, .contact::after, .pilot-section::after {
    content: ''; position: absolute; inset: 0; z-index: 1;
    pointer-events: none;
    background: radial-gradient(circle 320px at var(--mx, 50%) var(--my, 50%),
      color-mix(in srgb, var(--accent) 18%, transparent) 0%,
      color-mix(in srgb, var(--accent) 6%, transparent) 35%,
      transparent 75%);
    transition: opacity 0.3s ease;
    opacity: 0;
  }
  section.story:hover::after, .contact:hover::after, .pilot-section:hover::after {
    opacity: 1;
  }
  /* Dark sections — subtle scrim behind content for readability over animated shader */
  body.shader-mode .contact::before,
  body.shader-mode section.story.dark::before,
  body.shader-mode .pilot-section::before {
    content: ''; position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg,
      color-mix(in srgb, var(--dark) 35%, transparent) 0%,
      color-mix(in srgb, var(--dark) 15%, transparent) 50%,
      color-mix(in srgb, var(--dark) 45%, transparent) 100%);
    pointer-events: none;
    transition: background var(--transition-dur) ease;
  }

  /* Mode toggle button in nav */
  .mode-toggle {
    background: rgba(255,255,255,0.08); color: #fff; border: 1px solid rgba(255,255,255,0.14);
    padding: 8px 12px; border-radius: 999px;
    font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.18em;
    text-transform: uppercase; cursor: pointer;
    display: flex; align-items: center; gap: 8px;
    transition: background 0.2s, border-color 0.2s;
  }
  .mode-toggle:hover { background: rgba(255,255,255,0.18); border-color: var(--accent); }
  .mode-toggle .ico { width: 12px; height: 12px; }
  body.shader-mode .mode-toggle { background: var(--accent); color: var(--dark); border-color: var(--accent); }

  /* ── Scroll progress bar (top) ── */
  .scroll-progress {
    position: fixed; top: 0; left: 0; right: 0; height: 2px; z-index: 200;
    background: rgba(255,255,255,0.06);
  }
  .scroll-progress .bar {
    height: 100%; width: 0%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    transition: background var(--transition-dur) ease, box-shadow var(--transition-dur) ease;
  }

  /* ── PILL NAVBAR (centered floating capsule) ── */
  .nav {
    position: fixed; top: 18px; left: 50%; transform: translateX(-50%); z-index: 100;
    display: flex; align-items: center; gap: 8px;
    padding: 8px 8px 8px 24px;
    background: rgba(13,27,50,0.72);
    backdrop-filter: blur(10px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 999px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 500; letter-spacing: 0.04em;
    transition: background var(--transition-dur) ease;
    max-width: calc(100vw - 32px);
  }
  .nav strong {
    font-family: 'Manrope'; font-weight: 800; letter-spacing: -0.02em;
    font-size: 15px; color: #fff; padding-right: 16px;
    border-right: 1px solid rgba(255,255,255,0.18);
  }
  .nav .brand-link {
    text-decoration: none; cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .nav .brand-link:hover { opacity: 0.78; }
  .nav-links { display: flex; gap: 4px; }
  .nav a.link {
    color: #fff; opacity: 0.78; padding: 8px 16px; border-radius: 999px;
    transition: background 0.2s, opacity 0.2s, color 0.2s;
    position: relative;
  }
  .nav a.link:hover { opacity: 1; background: rgba(255,255,255,0.08); }
  .nav a.link.active {
    opacity: 1;
    background: color-mix(in srgb, var(--accent) 22%, transparent);
    color: #fff;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 50%, transparent);
  }
  .nav .cta-nav {
    background: var(--accent); color: #fff;
    padding: 11px 22px; border-radius: 999px;
    font-family: 'Manrope'; font-weight: 800; font-size: 13px;
    transition: background var(--transition-dur) ease, transform 0.2s, color 0.2s;
    box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 50%, transparent);
  }
  .nav .cta-nav:hover { background: #fff; color: var(--dark); transform: translateY(-1px); }

  /* ── METRICS (animated counters) ── */
  .metrics-row {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 32px;
    border-top: 1px solid color-mix(in srgb, var(--dark) 12%, transparent);
    padding-top: 24px;
  }
  .metric { text-align: left; }
  .metric .num {
    font-family: 'Manrope'; font-weight: 800;
    font-size: clamp(32px, 4vw, 52px); line-height: 1;
    letter-spacing: -0.03em; color: var(--dark);
  }
  .metric .num .unit {
    font-size: 0.45em; opacity: 0.5; margin-left: 4px; letter-spacing: 0;
  }
  .metric .label {
    font-family: 'JetBrains Mono'; font-size: 11px; letter-spacing: 0.2em;
    text-transform: uppercase; opacity: 0.6; margin-top: 12px;
  }
  .dark .metric .num { color: var(--primary); }

  /* ── Newsletter inline (under articles) ── */
  .newsletter-inline { flex: 1; min-width: 320px; max-width: 520px; }
  .newsletter-inline .nl-label {
    display: block; font-family: 'JetBrains Mono'; font-size: 10px;
    letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.6; margin-bottom: 10px;
  }
  .newsletter-inline .nl-row { display: flex; gap: 8px; }
  .newsletter-inline input {
    flex: 1; padding: 14px 18px;
    background: rgba(0,0,0,0.05);
    border: 1px solid color-mix(in srgb, var(--dark) 18%, transparent);
    border-radius: 999px;
    font-family: 'Inter'; font-size: 15px; color: var(--dark);
  }
  .newsletter-inline input:focus { outline: none; border-color: var(--accent); }
  .newsletter-inline button { white-space: nowrap; padding: 14px 22px !important; margin: 0 !important; }

  /* ── ARTICLES section ── */
  .articles-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 32px;
  }
  .article-card {
    background: color-mix(in srgb, var(--primary) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary) 12%, transparent);
    border-radius: 24px; overflow: hidden;
    cursor: pointer;
    transition: border-color var(--transition-dur) ease, transform 0.3s;
    display: flex; flex-direction: column;
    text-decoration: none; color: inherit;
  }
  .article-card:hover { border-color: var(--accent); transform: translateY(-3px); }
  .article-cover {
    aspect-ratio: 1200 / 630;
    background-size: contain; background-repeat: no-repeat; background-position: center;
    background-color: var(--dark);
  }
  .article-body { padding: 18px 22px 22px; }
  .article-card .meta {
    font-family: 'JetBrains Mono'; font-size: 10px; letter-spacing: 0.2em;
    text-transform: uppercase; opacity: 0.55;
  }
  .article-card h4 {
    font-family: 'Manrope'; font-weight: 700; font-size: 19px; line-height: 1.3;
    margin: 12px 0 10px; letter-spacing: -0.01em;
  }
  .article-card p {
    font-family: 'Inter'; font-size: 14px; line-height: 1.55; opacity: 0.72;
  }
  .article-card .read {
    font-family: 'JetBrains Mono'; font-size: 11px; margin-top: 16px;
    color: var(--accent); letter-spacing: 0.1em;
    transition: color var(--transition-dur) ease;
  }

  /* ── ROADMAP per product ── */
  .product-detail .roadmap {
    margin-top: 24px;
    padding: 16px 18px;
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    border: 1px dashed color-mix(in srgb, var(--accent) 35%, transparent);
    border-radius: 14px;
    transition: background var(--transition-dur) ease, border-color var(--transition-dur) ease;
  }
  .product-detail .roadmap h5 {
    font-family: 'JetBrains Mono'; font-size: 10px; letter-spacing: 0.25em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 8px;
    transition: color var(--transition-dur) ease;
  }
  .product-detail .roadmap ul {
    list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 4px 20px;
  }
  .product-detail .roadmap li {
    font-family: 'Inter'; font-size: 13px; opacity: 0.78;
    display: grid; grid-template-columns: auto 1fr; gap: 10px;
  }
  .product-detail .roadmap li::before {
    content: '○'; color: var(--accent); transition: color var(--transition-dur) ease;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh; padding: 130px 64px 80px;
    display: grid; grid-template-rows: auto 1fr auto;
    background-color: var(--dark);
    background-size: cover; background-position: center 50%;
    background-repeat: no-repeat;
    background-attachment: fixed; /* parallax-light effect */
    color: #fff; position: relative; overflow: hidden;
    transition: background-color var(--transition-dur) ease;
    will-change: background-position;
  }
  .hero::after {
    content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 30%;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent, color-mix(in srgb, var(--dark) 92%, transparent));
    transition: background var(--transition-dur) ease;
  }
  .hero.low-res { filter: saturate(1.18) contrast(1.06); }
  .hero.low-res::before {
    content: ''; position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background: repeating-linear-gradient(0deg,
      transparent 0, transparent 2px,
      color-mix(in srgb, var(--primary) 50%, transparent) 2px,
      color-mix(in srgb, var(--primary) 50%, transparent) 3px);
    opacity: 0.35;
  }
  .hero > * { position: relative; z-index: 2; }
  .hero .label {
    font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.3em;
    text-transform: uppercase; opacity: 0.95;
    text-shadow: 0 2px 12px rgba(0,0,0,0.6);
  }
  .hero .label .dot {
    display: inline-block; width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent); margin-right: 12px;
    box-shadow: 0 0 12px var(--accent);
    transition: background var(--transition-dur) ease;
    animation: pulse 2s ease-in-out infinite alternate;
    vertical-align: middle;
  }
  @keyframes pulse { from { opacity: 0.55; } to { opacity: 1; } }

  .hero-text-block {
    display: inline-block; max-width: 900px;
    padding: 28px 40px 32px 32px;
    background: linear-gradient(to right,
      rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.4) 65%, rgba(0,0,0,0) 100%);
    border-radius: 0 24px 24px 0;
    margin-left: -32px;
    backdrop-filter: blur(2px);
  }
  .hero h1 {
    font-family: 'Manrope'; font-weight: 800;
    font-size: clamp(48px, 8vw, 92px); line-height: 0.95;
    letter-spacing: -0.03em; text-transform: uppercase;
    margin: 8px 0 4px; color: #fff;
    text-shadow: 0 4px 24px rgba(0,0,0,0.45);
  }
  .hero h1 em {
    font-family: 'Fraunces'; font-style: italic; font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 100;
    text-transform: lowercase; letter-spacing: -0.015em;
  }
  .hero .body {
    font-family: 'Inter'; font-size: 16px; line-height: 1.65; opacity: 0.92;
    max-width: 520px; margin-top: 22px; padding-top: 20px;
    border-top: 1px solid var(--accent); color: #fff;
    transition: border-color var(--transition-dur) ease;
    text-shadow: 0 2px 12px rgba(0,0,0,0.5);
  }
  .scroll-hint {
    position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
    color: #fff; font-family: 'JetBrains Mono'; font-size: 10px; letter-spacing: 0.3em;
    text-transform: uppercase; opacity: 0.7;
    animation: bob 2.5s ease-in-out infinite;
  }
  @keyframes bob { 0%, 100% { transform: translate(-50%, 0); } 50% { transform: translate(-50%, 8px); } }

  /* CTA shared */
  .cta {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--accent); color: #fff;
    padding: 16px 32px; border-radius: 999px;
    font-family: 'Manrope'; font-weight: 800; font-size: 14px; letter-spacing: 0.02em;
    box-shadow: 0 8px 32px color-mix(in srgb, var(--accent) 50%, transparent);
    transition: background var(--transition-dur) ease, box-shadow var(--transition-dur) ease,
                transform 0.2s, color 0.2s;
    border: 2px solid transparent;
  }
  .cta:hover { background: #fff; color: var(--dark); transform: translateY(-2px); border-color: var(--accent); }
  .cta-light { background: var(--dark); color: #fff; }
  .cta-light:hover { background: var(--accent); color: #fff; border-color: var(--dark); }

  /* ── Section base ── */
  section.story {
    padding: 140px 64px 80px; /* top padding clears pill navbar (top:18px + height ~50px + breathing 70px) */
    position: relative; overflow: hidden;
    transition: background var(--transition-dur) ease, color var(--transition-dur) ease;
    display: flex; align-items: center;
  }
  section.story .container { width: 100%; }
  section.story.dark { background: var(--dark); color: var(--primary); }
  section.story.light { background: var(--bg); color: var(--dark); }
  .container { max-width: 1280px; margin: 0 auto; position: relative; }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.3em;
    text-transform: uppercase; opacity: 0.65; margin-bottom: 24px;
  }
  .eyebrow::before {
    content: '— '; color: var(--accent);
    transition: color var(--transition-dur) ease;
  }
  h2.section-title {
    font-family: 'Manrope'; font-weight: 800;
    font-size: clamp(40px, 5.5vw, 72px); line-height: 1.0;
    letter-spacing: -0.025em; text-transform: uppercase;
    margin-bottom: 28px;
  }
  h2.section-title em {
    font-family: 'Fraunces'; font-style: italic; font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 100;
    text-transform: lowercase; letter-spacing: -0.015em;
  }
  h2.section-title em .proper { text-transform: none; }
  .lede {
    font-family: 'Inter'; font-size: 19px; line-height: 1.5; font-weight: 400;
    max-width: 720px; margin-bottom: 28px; opacity: 0.9;
  }
  .placeholder-note {
    display: inline-block; margin-top: 20px;
    font-family: 'JetBrains Mono'; font-size: 10px;
    color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    padding: 4px 10px; border-radius: 6px; letter-spacing: 0.05em;
    transition: color var(--transition-dur) ease, border-color var(--transition-dur) ease, background var(--transition-dur) ease;
  }

  /* ── Section 02 — Pomagamy ── */
  .help-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; margin-top: 32px;
  }
  .help-photo {
    aspect-ratio: 4/3; border-radius: 28px; max-height: 360px;
    background-size: cover; background-position: center;
    box-shadow: 0 24px 64px rgba(0,0,0,0.25);
    transition: background-image var(--transition-dur) ease;
    background-image: url('/photos/hero-5236.jpg');
  }
  /* help-mock: OCR demo widget zamiast brand photo (sekcja 02 Pomagamy — Marcin pon 11.05 „chcę screenshot OCR Invoice Reader, nie zdjęcia") */
  .help-photo.help-mock {
    background-image: none !important;
    background: color-mix(in srgb, var(--dark) 92%, transparent);
    padding: 0; display: flex; align-items: stretch;
    aspect-ratio: 4/3; max-height: 360px;
  }
  .help-photo.help-mock .help-screenshot {
    margin: 0; flex: 1; min-height: 0;
    border-radius: 28px; border: 1px solid rgba(255,255,255,0.10);
  }
  .pain-list { list-style: none; }
  .pain-list li {
    padding: 12px 0; border-bottom: 1px solid color-mix(in srgb, var(--dark) 12%, transparent);
    display: grid; grid-template-columns: auto 1fr; gap: 14px;
    font-family: 'Inter'; font-size: 15px; line-height: 1.45;
  }
  .pain-list li:last-child { border-bottom: none; }
  .pain-list .ic {
    font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 700;
    color: var(--accent); padding-top: 2px;
    transition: color var(--transition-dur) ease;
  }

  /* ── Section 03 — Produkty (BENTO GRID — top row: flagship OCR+Email, bottom: pilot Deadline+Reporting) ── */
  .products-bento {
    display: grid; gap: 18px; margin-top: 32px;
    grid-template-columns: 1.3fr 1fr;
    grid-template-rows: 1.2fr 1fr;
    grid-template-areas:
      "ocr email"
      "deadline reporting";
    height: 56vh;
    min-height: 480px;
    transition: grid-template-columns 0.5s cubic-bezier(.4,1.2,.5,1), grid-template-rows 0.5s cubic-bezier(.4,1.2,.5,1);
  }
  /* Expanded states — clicked card grows, others shrink to side */
  .products-bento[data-expand="ocr"]      { grid-template-columns: 2.5fr 1fr; grid-template-rows: 2.3fr 1fr; }
  .products-bento[data-expand="email"]    { grid-template-columns: 1fr 2.5fr; grid-template-rows: 2.3fr 1fr; }
  .products-bento[data-expand="deadline"] { grid-template-columns: 2.5fr 1fr; grid-template-rows: 1fr 2.3fr; }
  .products-bento[data-expand="reporting"]{ grid-template-columns: 1fr 2.5fr; grid-template-rows: 1fr 2.3fr; }
  .bento-card { transition: border-color var(--transition-dur) ease, transform 0.4s cubic-bezier(.4,1.2,.5,1), box-shadow var(--transition-dur) ease, opacity 0.4s; }
  .products-bento[data-expand] .bento-card:not(.expanded) { opacity: 1; }
  .bento-card.expanded {
    border-color: var(--accent);
    box-shadow: 0 24px 64px color-mix(in srgb, var(--accent) 35%, transparent);
    background: rgba(13, 27, 50, 0.95) !important;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto auto;
    gap: 24px;
    text-align: left;
    max-height: 85vh;
    overflow-y: auto;
  }
  .bento-card.expanded > div:first-child {
    min-width: 0;
  }
  .bento-card.expanded .bento-screenshot {
    margin-top: 0;
    width: 100%;
    height: auto;
    min-height: 0;
  }
  .bento-card.expanded .bento-screenshot .body.with-image {
    aspect-ratio: 16 / 9;
    max-height: 40vh;
  }
  .bento-card.expanded .bento-screenshot .body.placeholder {
    min-height: 140px;
    max-height: 200px;
  }
  .products-bento[data-expand] { height: auto; min-height: 56vh; }
  .bento-card.expanded { scroll-margin-top: 120px; }
  .bento-screenshot .body.with-image { padding: 0; }
  .bento-screenshot .body.with-image img { width: 100%; height: 100%; object-fit: cover; object-position: left center; display: block; }
  .bento-card.expanded .bento-screenshot .body.with-image img { cursor: zoom-in; }

  /* ── Product screenshot lightbox ── */
  .product-lightbox {
    position: fixed; inset: 0; z-index: 10000;
    background: rgba(13, 27, 50, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center;
    padding: 5vh 5vw;
    cursor: zoom-out;
    animation: lightboxFade 0.2s ease;
  }
  @keyframes lightboxFade { from { opacity: 0; } to { opacity: 1; } }
  .product-lightbox img {
    max-width: 100%; max-height: 100%;
    border-radius: 12px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.5);
    cursor: default;
  }
  .product-lightbox .lightbox-close {
    position: absolute; top: 24px; right: 24px;
    width: 48px; height: 48px;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--primary) 30%, transparent);
    background: rgba(13,27,50,0.6); color: var(--primary);
    font-size: 24px; cursor: pointer; line-height: 1;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, border-color 0.2s;
  }
  .product-lightbox .lightbox-close:hover { background: var(--accent); border-color: var(--accent); }
  .bento-card .b-extra { display: none; margin-top: 14px; padding-top: 14px; border-top: 1px solid color-mix(in srgb, var(--primary) 14%, transparent); }
  .bento-card.expanded .b-extra { display: block; }
  .bento-card .b-extra h5 {
    font-family: 'JetBrains Mono'; font-size: 11px; letter-spacing: 0.22em;
    text-transform: uppercase; opacity: 0.95; margin-bottom: 10px; color: var(--accent);
  }
  .bento-card .b-extra ul {
    list-style: none; display: grid; grid-template-columns: 1fr; gap: 8px;
    font-family: 'Inter'; font-size: 14px;
  }
  .bento-card .b-extra ul li { padding: 4px 0; opacity: 0.88; display: flex; align-items: baseline; gap: 10px; }
  .bento-card .b-extra ul li::before { content: '▸'; color: var(--accent); font-family: 'JetBrains Mono'; flex-shrink: 0; }
  .bento-card .b-extra ul li strong { color: var(--accent); font-weight: 700; }
  .bento-card .b-extra .b-extra-desc {
    font-family: 'Inter'; font-size: 14px; line-height: 1.5;
    opacity: 0.9; margin: 0 0 4px 0; color: inherit;
  }
  /* Expand affordance — „+" w prawym górnym (klient widzi że karta klikalna) */
  .bento-card::after {
    content: '+';
    position: absolute; top: 16px; right: 20px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 24px; font-weight: 200; line-height: 1;
    color: var(--accent); opacity: 0.55;
    transition: opacity 0.3s, transform 0.3s, color 0.3s;
    pointer-events: none;
  }
  .bento-card:hover::after { opacity: 1; transform: scale(1.25); }
  .bento-card.expanded::after { content: '−'; opacity: 1; transform: scale(1.1); color: var(--sunset); }
  .bento-card {
    border-radius: 22px; padding: 22px 24px;
    position: relative; overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--primary) 22%, transparent);
    background: color-mix(in srgb, var(--dark) 78%, transparent);
    backdrop-filter: blur(10px) saturate(1.4);
    -webkit-backdrop-filter: blur(10px) saturate(1.4);
    transition: border-color var(--transition-dur) ease, transform 0.4s cubic-bezier(.4,1.4,.5,1), box-shadow var(--transition-dur) ease;
    cursor: pointer;
    display: flex; flex-direction: column; justify-content: space-between;
    color: var(--primary);
  }
  .bento-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 20px 56px color-mix(in srgb, var(--accent) 28%, transparent);
    background: color-mix(in srgb, var(--dark) 88%, transparent);
  }
  .bento-card[data-area="ocr"]      { grid-area: ocr; background: linear-gradient(160deg, color-mix(in srgb, var(--accent) 32%, color-mix(in srgb, var(--dark) 80%, transparent)), color-mix(in srgb, var(--dark) 85%, transparent)); }
  .bento-card[data-area="email"]    { grid-area: email; background: linear-gradient(200deg, color-mix(in srgb, var(--accent) 22%, color-mix(in srgb, var(--dark) 80%, transparent)), color-mix(in srgb, var(--dark) 85%, transparent)); }
  .bento-card[data-area="deadline"] { grid-area: deadline; background: linear-gradient(180deg, color-mix(in srgb, var(--sunset) 20%, color-mix(in srgb, var(--dark) 80%, transparent)), color-mix(in srgb, var(--dark) 85%, transparent)); }
  .bento-card[data-area="reporting"]{ grid-area: reporting; background: linear-gradient(200deg, color-mix(in srgb, var(--sunset) 25%, color-mix(in srgb, var(--dark) 80%, transparent)), color-mix(in srgb, var(--dark) 85%, transparent)); }

  .bento-card .b-num {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; opacity: 0.55;
    letter-spacing: 0.25em;
  }
  .bento-card .b-name {
    font-family: 'Manrope'; font-weight: 800;
    font-size: 26px; letter-spacing: -0.02em;
    margin: 8px 0 6px;
  }
  .bento-card[data-area="ocr"] .b-name { font-size: 38px; }
  .bento-card[data-area="reporting"] .b-name { font-size: 30px; }
  .bento-card .b-badge {
    display: inline-block;
    background: var(--accent); color: var(--dark);
    font-family: 'Manrope'; font-weight: 800; font-size: 9px;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 3px 10px; border-radius: 999px;
    transition: background var(--transition-dur) ease;
    align-self: flex-start;
  }
  .bento-card .b-desc {
    font-family: 'Inter'; font-size: 13px; line-height: 1.5; opacity: 0.78;
    margin-top: 8px;
  }
  .bento-card[data-area="ocr"] .b-desc { font-size: 15px; max-width: 88%; }

  /* Screenshot mockup — fake browser frame inline */
  .bento-screenshot {
    margin-top: 14px; flex: 0 0 auto; max-height: 140px; min-height: 0;
    background: rgba(0,0,0,0.22); border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.08);
    overflow: hidden; position: relative;
    display: flex; flex-direction: column;
  }
  .bento-screenshot .titlebar {
    height: 22px; padding: 0 10px;
    display: flex; align-items: center; gap: 5px;
    background: rgba(0,0,0,0.25);
    flex-shrink: 0;
  }
  .bento-screenshot .titlebar span {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,0.18);
  }
  .bento-screenshot .body {
    flex: 1; padding: 12px;
    background:
      linear-gradient(180deg, transparent 60%, color-mix(in srgb, var(--accent) 14%, transparent)),
      repeating-linear-gradient(0deg,
        rgba(255,255,255,0.03) 0px, rgba(255,255,255,0.03) 4px,
        transparent 4px, transparent 12px);
    transition: background var(--transition-dur) ease;
    position: relative;
    color: rgba(255,255,255,0.9);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
  }
  .bento-screenshot .body.placeholder::before {
    content: 'Screenshot wkrótce \00B7 UI w przebudowie';
    position: absolute; left: 50%; top: 50%; transform: translate(-50%,-50%);
    font-family: 'JetBrains Mono'; font-size: 9px; letter-spacing: 0.18em;
    text-transform: uppercase; opacity: 0.4;
    text-align: center; white-space: nowrap;
  }
  .bento-card.expanded .bento-screenshot .body.placeholder::before {
    font-size: 13px; letter-spacing: 0.15em; opacity: 0.5;
  }
  /* per-area min-heights removed — uniform 140px max keeps collapsed cards compact */

  /* ── Live OCR demo widget (inside bento card OCR) ── */
  .ocr-demo {
    display: grid; grid-template-columns: auto 1fr 1.2fr; gap: 10px;
    align-items: stretch; height: 100%;
    padding: 4px;
  }
  .ocr-doc {
    width: 50px; height: 64px;
    background: linear-gradient(135deg, #f5f3ee 0%, #e8e4dd 100%);
    border-radius: 4px; position: relative;
    box-shadow: 0 2px 8px rgba(0,0,0,0.4);
    align-self: center;
    display: flex; flex-direction: column; padding: 6px 4px; gap: 2px;
  }
  .ocr-doc::before {
    content: ''; position: absolute; top: 0; right: 0;
    width: 12px; height: 12px;
    background: linear-gradient(225deg, transparent 50%, #d8d4cd 50%);
    border-bottom-left-radius: 4px;
  }
  .ocr-doc-line {
    height: 2px; border-radius: 1px;
    background: rgba(13,27,50,0.35);
  }
  .ocr-doc-line:nth-child(1) { width: 80%; }
  .ocr-doc-line:nth-child(2) { width: 60%; }
  .ocr-doc-line:nth-child(3) { width: 70%; }
  .ocr-doc-line:nth-child(4) { width: 50%; margin-top: 4px; }
  .ocr-doc-line:nth-child(5) { width: 65%; }
  .ocr-arrow {
    align-self: center; display: flex; flex-direction: column; align-items: center; gap: 4px;
    color: var(--accent);
    transition: color var(--transition-dur) ease;
  }
  .ocr-arrow svg {
    width: 22px; height: 22px;
    animation: ocrPulse 2.6s ease-in-out infinite;
    filter: drop-shadow(0 0 6px var(--accent));
  }
  @keyframes ocrPulse {
    0%, 100% { transform: translateX(0); opacity: 0.65; }
    50%      { transform: translateX(4px); opacity: 1; }
  }
  .ocr-arrow .arrow-label {
    font-size: 8px; letter-spacing: 0.18em; text-transform: uppercase;
    opacity: 0.7; white-space: nowrap;
  }
  .ocr-fields {
    display: grid; grid-template-rows: auto auto auto auto; gap: 5px;
    align-content: center;
    font-size: 10px; line-height: 1.3;
  }
  .ocr-fields .row {
    display: grid; grid-template-columns: auto 1fr; gap: 6px; align-items: baseline;
    padding: 3px 6px; background: rgba(0,0,0,0.25); border-radius: 4px;
    border-left: 2px solid var(--accent);
    transition: border-color var(--transition-dur) ease;
    opacity: 0; animation: ocrAppear 6.8s ease-in-out infinite;
  }
  .ocr-fields .row:nth-child(1) { animation-delay: 0.5s; }
  .ocr-fields .row:nth-child(2) { animation-delay: 1.6s; }
  .ocr-fields .row:nth-child(3) { animation-delay: 2.7s; }
  .ocr-fields .row:nth-child(4) { animation-delay: 3.8s; }
  @keyframes ocrAppear {
    0%, 5%   { opacity: 0; transform: translateY(4px); }
    10%, 75% { opacity: 1; transform: translateY(0); }
    85%, 100%{ opacity: 0; transform: translateY(-2px); }
  }
  .ocr-fields .key {
    color: var(--accent); font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    font-size: 8px;
    transition: color var(--transition-dur) ease;
  }
  .ocr-fields .val {
    color: rgba(255,255,255,0.95);
    font-feature-settings: 'tnum' 1;
  }

  @media (max-width: 900px) {
    .products-bento { grid-template-columns: 1fr; grid-template-rows: auto; grid-template-areas: "ocr" "email" "deadline" "reporting"; height: auto; }
  }

  /* ── Section 04 — Proces (interactive) ── */
  .process-line { position: relative; margin-top: 32px; }
  .process-line::before {
    content: ''; position: absolute; left: 0; right: 0; top: 76px; height: 2px;
    background: color-mix(in srgb, var(--dark) 14%, transparent);
  }
  .process-line .progress-fill {
    position: absolute; left: 0; top: 76px; height: 2px;
    background: var(--accent); width: 50%;
    transition: width 0.5s ease, background var(--transition-dur) ease;
    box-shadow: 0 0 8px var(--accent);
  }
  .process-stations {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;
    position: relative;
  }
  .station {
    text-align: center; cursor: pointer;
    background: transparent; border: 0; color: inherit;
    padding: 0 8px;
    transition: transform 0.3s;
  }
  .station:hover { transform: translateY(-4px); }
  .station .tick {
    width: 16px; height: 16px; border-radius: 50%;
    background: var(--bg); border: 2px solid color-mix(in srgb, var(--dark) 30%, transparent);
    margin: 30px auto; position: relative;
    transition: background var(--transition-dur) ease, border-color var(--transition-dur) ease, box-shadow 0.3s;
  }
  .station.active .tick, .station:hover .tick {
    background: var(--accent); border-color: var(--accent);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--accent) 18%, transparent);
  }
  .station .num {
    font-family: 'Manrope'; font-weight: 800; font-size: 56px; line-height: 1;
    letter-spacing: -0.03em; color: var(--dark);
    opacity: 0.7;
    transition: opacity 0.3s, color var(--transition-dur) ease;
  }
  .station.active .num, .station:hover .num { opacity: 1; }
  .station.active .num { color: var(--accent); }
  .station .label {
    font-family: 'JetBrains Mono', monospace; font-size: 12px;
    text-transform: uppercase; letter-spacing: 0.2em; margin-top: 16px;
    color: var(--dark); opacity: 0.85;
    transition: opacity 0.3s;
  }
  .station.active .label, .station:hover .label { opacity: 1; }
  .station .desc {
    font-family: 'Inter'; font-size: 13px; line-height: 1.5; opacity: 0.72;
    margin-top: 10px; max-height: 120px;
    color: var(--dark);
    transition: opacity 0.4s;
  }
  .station.active .desc, .station:hover .desc {
    opacity: 0.95;
  }

  /* ── Section 05 — Pilot CTA ── */
  .pilot-section {
    background: var(--dark) !important; color: #fff;
    background-image:
      linear-gradient(to bottom, color-mix(in srgb, var(--dark) 88%, transparent), color-mix(in srgb, var(--dark) 95%, transparent)),
      url('/photos/hero-5350.jpg');
    background-size: cover; background-position: center;
    background-blend-mode: normal;
  }
  .pilot-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 48px; margin-top: 28px;
    align-items: stretch; /* equal heights */
  }
  .pilot-points {
    display: flex; flex-direction: column; justify-content: center;
  }
  .pilot-points li {
    list-style: none; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.12);
    font-size: 15px; opacity: 0.92;
    display: grid; grid-template-columns: auto 1fr; gap: 16px; align-items: baseline;
  }
  .pilot-points .ic {
    font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 700;
    color: var(--accent); letter-spacing: 0.1em;
    transition: color var(--transition-dur) ease;
  }
  .pilot-form {
    background: rgba(0,0,0,0.4); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 28px; padding: 32px;
  }
  .pilot-form label {
    display: block; font-family: 'JetBrains Mono'; font-size: 10px;
    letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.6; margin-bottom: 6px;
  }
  .pilot-form input, .pilot-form textarea {
    width: 100%; padding: 12px 14px; margin-bottom: 16px;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.14);
    border-radius: 12px; color: #fff;
    font-family: 'Inter'; font-size: 15px;
  }
  .pilot-form input:focus, .pilot-form textarea:focus {
    outline: none; border-color: var(--accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 25%, transparent);
  }

  /* ── Section 06 — Kontakt + footer ── */
  .contact {
    background: var(--dark); color: #fff; padding: 140px 64px 40px;
    display: flex; flex-direction: column; justify-content: flex-start;
    position: relative; overflow: hidden; /* anchor for shader iframe */
  }
  .contact > .container { position: relative; z-index: 2; }
  .contact > .footer-bar { position: relative; z-index: 2; }
  .contact h2 {
    font-family: 'Manrope'; font-weight: 800; font-size: 48px; letter-spacing: -0.025em;
    margin-bottom: 28px;
  }
  .contact-split {
    display: grid; grid-template-columns: 1.1fr 1fr; gap: 56px; margin-top: 32px;
    margin-bottom: 56px; align-items: start;
  }
  .contact-form { backdrop-filter: blur(8px); }
  .contact-info { display: flex; flex-direction: column; gap: 24px; }
  .contact-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;
  }
  @media (max-width: 900px) {
    .contact-split { grid-template-columns: 1fr; gap: 32px; }
  }
  .contact-grid > div { padding-left: 0; }
  .contact-grid .ico {
    width: 28px; height: 28px;
    color: var(--accent);
    transition: color var(--transition-dur) ease, transform 0.3s;
    margin-bottom: 14px; display: block;
  }
  .contact-grid > div:hover .ico { transform: translateY(-2px); }
  .contact-grid a:hover {
    color: var(--accent);
    transition: color var(--transition-dur) ease;
  }
  .contact-grid .placeholder {
    opacity: 0.45; font-style: italic;
  }
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .contact-grid > div { font-family: 'Inter'; font-size: 14px; line-height: 1.7; }
  .contact-grid h4 {
    font-family: 'JetBrains Mono'; font-size: 11px; letter-spacing: 0.2em;
    text-transform: uppercase; opacity: 0.5; margin-bottom: 12px;
  }
  .footer-bar {
    border-top: 1px solid rgba(255,255,255,0.12);
    padding-top: 24px;
    display: flex; justify-content: space-between; opacity: 0.6;
    font-family: 'JetBrains Mono'; font-size: 11px;
  }

  /* ── HUD (carousel info) ── */
  .hud {
    position: fixed; bottom: 24px; right: 24px; z-index: 50;
    background: rgba(0,0,0,0.7); backdrop-filter: blur(10px);
    color: #fff; padding: 14px 18px; border-radius: 12px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px; line-height: 1.6;
    border: 1px solid rgba(255,255,255,0.12); min-width: 240px;
  }
  .hud .lbl { opacity: 0.5; letter-spacing: 0.15em; text-transform: uppercase; font-size: 9px; }
  .hud .row { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-top: 4px; }
  .hud .swatch { display: inline-block; width: 14px; height: 14px; border-radius: 50%; vertical-align: middle; margin-right: 6px; border: 1px solid rgba(255,255,255,0.25); }
  .hud .progress { height: 2px; background: rgba(255,255,255,0.15); border-radius: 2px; overflow: hidden; margin-top: 8px; }
  .hud .progress .bar { height: 100%; background: var(--accent); width: 0%; transition: background var(--transition-dur) ease; }
  .hud button {
    background: rgba(255,255,255,0.1); color: #fff; border: 0;
    padding: 4px 8px; border-radius: 6px; font-family: 'JetBrains Mono'; font-size: 10px;
    cursor: pointer; margin-left: 6px;
  }
  .hud button:hover { background: rgba(255,255,255,0.25); }

  @media (max-width: 900px) {
    .help-grid, .pilot-grid, .products-split, .process-stations, .articles-grid { grid-template-columns: 1fr; gap: 24px; }
    .contact-grid { grid-template-columns: repeat(2, 1fr); }
    section.story { padding: 110px 24px 60px; }
    .nav { padding: 6px 6px 6px 16px; gap: 4px; font-size: 11px; overflow-x: auto; }
    .nav-links { display: none; }
  }

  /* Phone-specific fine-tune (≤480px) — fix hero overflow + nav cramped */
  @media (max-width: 480px) {
    .nav { padding: 5px 5px 5px 12px; font-size: 10px; gap: 3px; }
    .nav .cta-nav { padding: 6px 10px; font-size: 10px; }
    .hero h1 { font-size: clamp(32px, 9vw, 56px); }
    .hero-text-block { padding: 20px 20px 24px 24px; margin-left: -24px; max-width: calc(100vw - 8px); }
    .hero h1 em { letter-spacing: -0.01em; }
    section.story { padding: 80px 18px 48px; }
    section.story h2.section-title { font-size: clamp(28px, 7vw, 40px); word-wrap: break-word; }
    .station .num { font-size: 42px; }
    .station .desc { font-size: 12px; }
