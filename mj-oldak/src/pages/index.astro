<script>
const ROTATE_MS = 8000;
const VER = '?v=4';
let photos = [], idx = 0, timer = null, progressTimer = null, paused = false;

async function loadPhotos() {
  const r = await fetch('/photos.json' + VER);
  photos = await r.json();
  photos.forEach(p => { const im = new Image(); im.src = p.src + VER; });
  // Daily Hero photo rotation — different baseline image each calendar day
  const today = new Date();
  const dayOfYear = Math.floor((today - new Date(today.getFullYear(), 0, 0)) / 86400000);
  apply(dayOfYear % photos.length);
  start();
}

function apply(i) {
  idx = i;
  const p = photos[idx];
  const hero = document.getElementById('hero');
  hero.style.backgroundImage = `url('${p.src}${VER}')`;
  hero.dataset.photo = p.name;
  hero.classList.toggle('low-res', !!p.lowRes);
  // Brand colors LOCKED do sea-blue + sand (wartime brand consistency).
  // Photo rotuje wizualnie ale --accent + --dark zostają z :root.
  // (Removed: documentElement.style.setProperty('--accent', p.accent);
  //           documentElement.style.setProperty('--dark', p.dark);)
  // Subtle photo behind the "Pomagamy" section uses a different image — rotate it too
  const helpPhoto = document.getElementById('helpPhoto');
  if (helpPhoto) {
    helpPhoto.style.backgroundImage = `url('${p.src}${VER}')`;
  }
  document.getElementById('hudName').textContent = p.name.replace('IMG_','');
  document.getElementById('hudHex').textContent = p.accent;
  document.getElementById('hudSwatch').style.background = p.accent;
  resetProgress();
}

function next() { apply((idx + 1) % photos.length); restart(); }
function prev() { apply((idx - 1 + photos.length) % photos.length); restart(); }
function start() {
  // Auto-rotate disabled when user scrolls — sections drive theme
  // Re-enabled if user pauses at top (hero) for >ROTATE_MS without scrolling
  // For now: keep timer as fallback at hero only
}
function stop() { if (timer) clearInterval(timer); if (progressTimer) clearInterval(progressTimer); timer = progressTimer = null; }
function restart() { stop(); resetProgress(); if (!paused) start(); }
function togglePause() {
  paused = !paused;
  document.getElementById('pauseBtn').textContent = paused ? '▶' : '⏸';
  if (paused) stop(); else start();
}
function resetProgress() {
  const bar = document.getElementById('hudBar');
  bar.style.width = '0%';
  if (progressTimer) clearInterval(progressTimer);
  if (paused) return;
  let elapsed = 0;
  progressTimer = setInterval(() => {
    elapsed += 50;
    const pct = Math.min(100, (elapsed / ROTATE_MS) * 100);
    bar.style.width = pct + '%';
    if (pct >= 100) clearInterval(progressTimer);
  }, 50);
}

loadPhotos();

// Cursor spotlight: mouse position → CSS variables per section
document.querySelectorAll('section.story, .contact, .pilot-section').forEach(sec => {
  sec.addEventListener('mousemove', e => {
    const r = sec.getBoundingClientRect();
    const x = ((e.clientX - r.left) / r.width) * 100;
    const y = ((e.clientY - r.top) / r.height) * 100;
    sec.style.setProperty('--mx', x + '%');
    sec.style.setProperty('--my', y + '%');
  });
});

// ─── Photo / Shader mode toggle (Hero only — sections always have ambient shader) ───
const STORAGE_KEY = 'mjoldak-bg-mode';

// Shader iframes load ONLY on shader-mode opt-in (6 iframes × rAF loop = lag).
// Default mode: sections rely on CSS scrim/vignette as ambient fallback.

// SHADER toggle removed — useless dla biur rachunkowych audience.
// Shader iframes stay in HTML (CSS scrim/vignette fallback in place) but never load src.

// ── Products inverse-reader (PRESERVED for backlog reference) ──
const PRODUCTS_LEGACY = [
  {
    num: '01', name: 'OCR Invoice Reader', badge: 'Live u klienta',
    lede: 'Faktura PDF, zdjęcie lub skan → dane strukturalne (NIP, kwoty, VAT) za 8 sekund. JSON do Comarch / Optima / iFirma.',
    feats: ['Azure Document Intelligence','Claude post-processing','PL VAT, NIP walidacja','API + UI do biura'],
    roadmap: ['Auto-import do Comarch','Polski JPK detection','Faktura korygująca'],
  },
  {
    num: '02', name: 'Email Assistant', badge: 'Beta',
    lede: 'Klasyfikacja maili (klient, US, ZUS) + automatyczne szkice + integracja Gmail/Calendar. Inbox biura pod kontrolą.',
    feats: ['Auto-klasyfikacja folderów','AI szkice odpowiedzi','Gmail/Calendar sync','Reguły per klient'],
    roadmap: ['Outlook 365','SMS bridge','Per-klient ton-of-voice'],
  },
  {
    num: '03', name: 'Deadline Agent', badge: 'Pilot',
    lede: 'Deadline\'y podatkowe (VAT, PIT, CIT), JPK_V7, KSeF per klient. Przypomnienia na czas, eskalacja po terminie.',
    feats: ['Kalendarz podatkowy 2026','Per-klient timeline','KSeF tracking','Email + SMS reminder'],
    roadmap: ['KSeF API live','SMS gateway PL','Auto-fill VAT-7 prep'],
  },
  {
    num: '04', name: 'Reporting Agent', badge: 'Pilot',
    lede: 'Raporty klientowskie z danych księgowych — auto-PDF + email. Miesięczne podsumowanie, prognoza VAT. Bez Excela.',
    feats: ['PDF auto-generated','Email do klienta','Miesięczne podsumowanie','Brand klienta na PDF'],
    roadmap: ['Charts & wykresy','Comarch/Optima sync','WhatsApp delivery'],
  },
];
// Bento grid — click to expand, click again to collapse
{
  const bento = document.getElementById('productsBento');
  if (bento) {
    document.querySelectorAll('#productsBento .bento-card').forEach(card => {
      card.addEventListener('click', () => {
        const area = card.dataset.area;
        const wasExpanded = card.classList.contains('expanded');
        document.querySelectorAll('#productsBento .bento-card').forEach(c => c.classList.remove('expanded'));
        if (wasExpanded) {
          bento.removeAttribute('data-expand');
          setTimeout(() => {
            const productsEl = document.getElementById('products');
            const y = productsEl.getBoundingClientRect().top + window.pageYOffset - 80;
            window.scrollTo({top: y, behavior: 'smooth'});
          }, 200);
        } else {
          card.classList.add('expanded');
          bento.setAttribute('data-expand', area);
          setTimeout(() => card.scrollIntoView({behavior: 'smooth', block: 'start'}), 50);
        }
      });
    });
    // Click outside collapses
    document.addEventListener('click', (e) => {
      if (!bento.contains(e.target)) {
        document.querySelectorAll('#productsBento .bento-card').forEach(c => c.classList.remove('expanded'));
        bento.removeAttribute('data-expand');
      }
    });
    // Screenshot lightbox — click image in expanded card to zoom (NOT collapse parent)
    document.querySelectorAll('#productsBento .bento-screenshot .body.with-image img').forEach(img => {
      img.addEventListener('click', (e) => {
        if (!img.closest('.bento-card.expanded')) return;
        e.stopPropagation();
        openProductLightbox(img.src, img.alt);
      });
    });
  }
}

function openProductLightbox(src, alt) {
  const overlay = document.createElement('div');
  overlay.className = 'product-lightbox';
  overlay.innerHTML = `<button class="lightbox-close" aria-label="Zamknij">×</button><img src="${src}" alt="${alt || ''}">`;
  document.body.appendChild(overlay);
  document.body.style.overflow = 'hidden';
  const close = () => {
    overlay.remove();
    document.body.style.overflow = '';
    document.removeEventListener('keydown', onEsc);
  };
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay || e.target.classList.contains('lightbox-close')) close();
  });
  const onEsc = (e) => { if (e.key === 'Escape') close(); };
  document.addEventListener('keydown', onEsc);
}

// ─── A) Scroll progress bar + scroll-spy ───
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav a.link');
window.addEventListener('scroll', () => {
  const sH = document.documentElement.scrollHeight - window.innerHeight;
  const pct = (window.scrollY / sH) * 100;
  document.getElementById('scrollBar').style.width = pct + '%';
}, { passive: true });

const spyObserver = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const id = e.target.id;
      navLinks.forEach(a => a.classList.toggle('active', a.dataset.spy === id));
      // Section-triggered photo change REMOVED — Hero photo zostaje daily, stała przez sesję.
      // Marcin: „przewijam i widzę kolejne zdjęcie wjeżdża, przewijam do góry trzecie zdjęcie = zbukowane".
    }
  });
}, { threshold: 0.45 });
sections.forEach(s => spyObserver.observe(s));

// ─── B) Animated metric counters ───
const metricsObserver = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.querySelectorAll('.num[data-target]').forEach(el => {
        if (el.dataset.done) return;
        el.dataset.done = '1';
        const target = parseInt(el.dataset.target);
        const dur = 1400;
        const start = performance.now();
        const unit = el.querySelector('.unit')?.outerHTML || '';
        function step(now) {
          const t = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - t, 3); // ease-out cubic
          const val = Math.floor(target * eased);
          el.innerHTML = val + unit;
          if (t < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      });
      metricsObserver.unobserve(e.target);
    }
  });
}, { threshold: 0.4 });
const mr = document.getElementById('metricsRow');
if (mr) metricsObserver.observe(mr);

// ─── C) Magnetic CTA buttons ───
document.querySelectorAll('.magnet').forEach(btn => {
  btn.addEventListener('mousemove', e => {
    const r = btn.getBoundingClientRect();
    const x = e.clientX - r.left - r.width/2;
    const y = e.clientY - r.top - r.height/2;
    const strength = 0.18;
    btn.style.transform = `translate(${x*strength}px, ${y*strength}px)`;
  });
  btn.addEventListener('mouseleave', () => {
    btn.style.transform = '';
  });
});

// ─── Process — auto-rotate stations co 5s + click pauses auto ───
{
  const stationBtns = document.querySelectorAll('#processStations .station');
  const fill = document.getElementById('processFill');
  let processIdx = 0;
  let processTimer = null;

  function setStation(i) {
    processIdx = i;
    stationBtns.forEach((el, j) => el.classList.toggle('active', j === i));
    if (fill) fill.style.width = (12.5 + i * 25) + '%';
  }
  function rotateProcess() { setStation((processIdx + 1) % stationBtns.length); }
  function startAutoRotate() {
    if (processTimer || !stationBtns.length) return;
    processTimer = setInterval(rotateProcess, 5000);
  }
  function stopAutoRotate() {
    if (processTimer) { clearInterval(processTimer); processTimer = null; }
  }

  stationBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      stopAutoRotate();
      setStation(parseInt(btn.dataset.step));
    });
  });

  // Pause auto-rotate when Process section is off-screen (saves rAF/timer cost)
  const processSection = document.getElementById('process');
  if (processSection && stationBtns.length) {
    setStation(0);
    new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) startAutoRotate();
        else stopAutoRotate();
      });
    }, { threshold: 0.3 }).observe(processSection);
  }
}

// ─── D) Hero parallax ───
// background-attachment: fixed already gives base parallax effect on most browsers.
// Add subtle JS parallax for background-position-y when scrolling within hero
const hero = document.getElementById('hero');
window.addEventListener('scroll', () => {
  if (!hero) return;
  const y = window.scrollY;
  const heroH = hero.offsetHeight;
  if (y < heroH) {
    const offset = 50 + (y / heroH) * 25; // 50% → 75%
    hero.style.backgroundPosition = `center ${offset}%`;
  }
}, { passive: true });

</script>



