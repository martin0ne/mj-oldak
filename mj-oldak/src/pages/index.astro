<script>
const ROTATE_MS = 8000;
const VER = '?v=4';
let photos = [], idx = 0, timer = null, progressTimer = null, paused = false;

async function loadPhotos() {
  const r = await fetch('/photos.json' + VER);
  photos = await r.json();
  // console.log('photos.json loaded:', photos.length);
  photos.forEach(p => { const im = new Image(); im.src = p.src + VER; });
  apply(0);
  start();
}

function apply(i) {
  idx = i;
  const p = photos[idx];
  // console.log('apply →', p.name, p.accent);
  const hero = document.getElementById('hero');
  hero.style.backgroundImage = `url('${p.src}${VER}')`;
  hero.classList.toggle('low-res', !!p.lowRes);
  document.documentElement.style.setProperty('--accent', p.accent);
  document.documentElement.style.setProperty('--dark', p.dark);
  // Subtle photo behind the "Pomagamy" section uses a different image — rotate it too
  const helpPhoto = document.getElementById('helpPhoto');
  if (helpPhoto) {
    helpPhoto.style.backgroundImage = `url('${p.src}${VER}')`;
  }
  document.getElementById('hudName').textContent = p.name.replace('IMG_','');
  document.getElementById('hudHex').textContent = p.accent;
  document.getElementById('hudSwatch').style.background = p.accent;
  resetProgress();
}

function next() { apply((idx + 1) % photos.length); restart(); }
function prev() { apply((idx - 1 + photos.length) % photos.length); restart(); }
function start() {
  // Auto-rotate disabled when user scrolls — sections drive theme
  // Re-enabled if user pauses at top (hero) for >ROTATE_MS without scrolling
  // For now: keep timer as fallback at hero only
}
function stop() { if (timer) clearInterval(timer); if (progressTimer) clearInterval(progressTimer); timer = progressTimer = null; }
function restart() { stop(); resetProgress(); if (!paused) start(); }
function togglePause() {
  paused = !paused;
  document.getElementById('pauseBtn').textContent = paused ? '▶' : '⏸';
  if (paused) stop(); else start();
}
function resetProgress() {
  const bar = document.getElementById('hudBar');
  bar.style.width = '0%';
  if (progressTimer) clearInterval(progressTimer);
  if (paused) return;
  let elapsed = 0;
  progressTimer = setInterval(() => {
    elapsed += 50;
    const pct = Math.min(100, (elapsed / ROTATE_MS) * 100);
    bar.style.width = pct + '%';
    if (pct >= 100) clearInterval(progressTimer);
  }, 50);
}

loadPhotos();

// Cursor spotlight: mouse position → CSS variables per section
document.querySelectorAll('section.story, .contact, .pilot-section').forEach(sec => {
  sec.addEventListener('mousemove', e => {
    const r = sec.getBoundingClientRect();
    const x = ((e.clientX - r.left) / r.width) * 100;
    const y = ((e.clientY - r.top) / r.height) * 100;
    sec.style.setProperty('--mx', x + '%');
    sec.style.setProperty('--my', y + '%');
  });
});

// ─── Photo / Shader mode toggle (Hero only — sections always have ambient shader) ───
const STORAGE_KEY = 'mjoldak-bg-mode';

// Load ALL shader iframes immediately (sections need them as ambient bg, hero lazy)
document.querySelectorAll('iframe.shader-bg[data-shader-src]').forEach(f => {
  // Skip hero iframe — load only when shader-mode active to save resources
  const isHero = f.closest('.hero') !== null;
  if (!isHero && !f.src) f.src = f.dataset.shaderSrc;
});

function setMode(mode) {
  document.body.classList.toggle('shader-mode', mode === 'shader');
  document.getElementById('modeLabel').textContent = mode === 'shader' ? 'PHOTO' : 'SHADER';
  localStorage.setItem(STORAGE_KEY, mode);
  // Lazy-load hero shader only when entering shader mode
  if (mode === 'shader') {
    document.querySelectorAll('.hero iframe.shader-bg[data-shader-src]').forEach(f => {
      if (!f.src) f.src = f.dataset.shaderSrc;
    });
  }
}
const initialMode = localStorage.getItem(STORAGE_KEY) || 'photo';
setMode(initialMode);
document.getElementById('modeToggle').addEventListener('click', () => {
  const current = document.body.classList.contains('shader-mode') ? 'shader' : 'photo';
  setMode(current === 'shader' ? 'photo' : 'shader');
});

// ── Products inverse-reader (PRESERVED for backlog reference) ──
const PRODUCTS_LEGACY = [
  {
    num: '01', name: 'OCR Invoice Reader', badge: 'Live u klienta',
    lede: 'Faktura PDF, zdjęcie lub skan → dane strukturalne (NIP, kwoty, VAT) za 8 sekund. JSON do Comarch / Optima / iFirma.',
    feats: ['Azure Document Intelligence','Claude post-processing','PL VAT, NIP walidacja','API + UI do biura'],
    roadmap: ['Auto-import do Comarch','Polski JPK detection','Faktura korygująca'],
  },
  {
    num: '02', name: 'Email Assistant', badge: 'Beta',
    lede: 'Klasyfikacja maili (klient, US, ZUS) + automatyczne szkice + integracja Gmail/Calendar. Inbox biura pod kontrolą.',
    feats: ['Auto-klasyfikacja folderów','AI szkice odpowiedzi','Gmail/Calendar sync','Reguły per klient'],
    roadmap: ['Outlook 365','SMS bridge','Per-klient ton-of-voice'],
  },
  {
    num: '03', name: 'Deadline Agent', badge: 'Pilot',
    lede: 'Deadline\'y podatkowe (VAT, PIT, CIT), JPK_V7, KSeF per klient. Przypomnienia na czas, eskalacja po terminie.',
    feats: ['Kalendarz podatkowy 2026','Per-klient timeline','KSeF tracking','Email + SMS reminder'],
    roadmap: ['KSeF API live','SMS gateway PL','Auto-fill VAT-7 prep'],
  },
  {
    num: '04', name: 'Reporting Agent', badge: 'Pilot',
    lede: 'Raporty klientowskie z danych księgowych — auto-PDF + email. Miesięczne podsumowanie, prognoza VAT. Bez Excela.',
    feats: ['PDF auto-generated','Email do klienta','Miesięczne podsumowanie','Brand klienta na PDF'],
    roadmap: ['Charts & wykresy','Comarch/Optima sync','WhatsApp delivery'],
  },
];
// Bento grid — click to expand, click again to collapse
{
  const bento = document.getElementById('productsBento');
  if (bento) {
    document.querySelectorAll('#productsBento .bento-card').forEach(card => {
      card.addEventListener('click', () => {
        const area = card.dataset.area;
        const wasExpanded = card.classList.contains('expanded');
        document.querySelectorAll('#productsBento .bento-card').forEach(c => c.classList.remove('expanded'));
        if (wasExpanded) {
          bento.removeAttribute('data-expand');
        } else {
          card.classList.add('expanded');
          bento.setAttribute('data-expand', area);
        }
      });
    });
    // Click outside collapses
    document.addEventListener('click', (e) => {
      if (!bento.contains(e.target)) {
        document.querySelectorAll('#productsBento .bento-card').forEach(c => c.classList.remove('expanded'));
        bento.removeAttribute('data-expand');
      }
    });
  }
}

// ─── A) Scroll progress bar + scroll-spy ───
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav a.link');
window.addEventListener('scroll', () => {
  const sH = document.documentElement.scrollHeight - window.innerHeight;
  const pct = (window.scrollY / sH) * 100;
  document.getElementById('scrollBar').style.width = pct + '%';
}, { passive: true });

const spyObserver = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const id = e.target.id;
