---
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft);
const latest = all
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const fmtDate = (d: Date) => new Intl.DateTimeFormat('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);
---
{latest.length > 0 && (
  <section id="artykuly-latest" class="bg-background py-32 px-6 md:px-12 relative">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 flex flex-col md:flex-row md:items-end md:justify-between gap-8">
        <div>
          <div class="flex items-center gap-2 mb-4">
            <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
            <span class="font-mono text-[10px] uppercase tracking-widest text-dark/40">[ 05 / ARTYKUŁY ]</span>
          </div>
          <h2 class="font-sans font-bold text-5xl md:text-7xl uppercase tracking-tight text-dark leading-none mb-4">
            Praktyczna <span class="font-serif italic font-normal text-accent">wiedza.</span>
          </h2>
          <p class="font-mono text-base text-dark/60 max-w-xl leading-relaxed">
            AI dla polskich firm bez ściemy. Case studies, koszty wdrożeń, kompliance.
          </p>
        </div>
        <a href="/artykuly/" class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-accent hover:gap-3 transition-all no-underline self-start md:self-end">
          Wszystkie artykuły
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {latest.map((a) => {
          const slug = a.id.replace(/\.md$/, '');
          return (
            <a href={`/artykuly/${slug}/`} class="group block rounded-[2rem] bg-dark/[0.05] border border-dark/10 hover:border-accent/40 hover:bg-dark/[0.07] transition-all overflow-hidden no-underline">
              {a.data.cover && (
                <div class="aspect-[16/9] overflow-hidden bg-dark/[0.05]">
                  <img src={a.data.cover} alt={a.data.coverAlt ?? a.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                </div>
              )}
              <div class="p-6">
                <div class="flex items-center gap-2 mb-3 font-mono text-[10px] uppercase tracking-widest text-dark/40">
                  <span class="text-accent">{a.data.category}</span>
                  <span>·</span>
                  <span>{fmtDate(a.data.publishedAt)}</span>
                </div>
                <h3 class="font-sans font-bold text-lg uppercase tracking-tight text-dark mb-2 group-hover:text-accent transition leading-tight">
                  {a.data.title}
                </h3>
                <p class="font-mono text-xs text-dark/60 leading-relaxed line-clamp-3">
                  {a.data.excerpt}
                </p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
)}

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
