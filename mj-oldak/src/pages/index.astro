---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavbarPersonal from '../components/personal/NavbarPersonal.jsx';
import HeroPersonal from '../components/personal/HeroPersonal.jsx';
import AboutSection from '../components/personal/AboutSection.jsx';
import Work from '../components/personal/Work.astro';
import Skills from '../components/personal/Skills.astro';
import OpenSource from '../components/personal/OpenSource.astro';
import Analytics from '../components/personal/Analytics.astro';
import Writing from '../components/personal/Writing.astro';
import ContactPersonal from '../components/personal/ContactPersonal.jsx';

const title = 'Marcin J. Ołdak — AI Automation Builder / AI Business Analyst';
const description = 'AI automation builder / AI business analyst — autonomous AI agents, n8n automation, LLM apps from PoC to pilot. 5 pilot-ready products + live demos.';
---
<BaseLayout title={title} description={description} lang="en" includeOrganizationSchema={true}>
  <NavbarPersonal client:load />
  <HeroPersonal client:load />
  <AboutSection client:visible />
  <Work />
  <Skills />
  <OpenSource />
  <Analytics />
  <Writing />
  <ContactPersonal client:visible />
</BaseLayout>
