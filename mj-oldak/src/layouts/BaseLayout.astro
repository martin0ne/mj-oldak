---
import '../styles/global.css';
import AccessibilityControls from '../components/personal/AccessibilityControls.jsx';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  author?: string;
  tags?: string[];
  includeOrganizationSchema?: boolean;
  lang?: string;
}

const {
  title = 'MJ.OLDAK — AI Systems & Automation',
  description = 'Wdrożenia AI dla biur rachunkowych w Polsce. Automatyzacja procesów, integracja systemów.',
  canonical,
  ogImage = '/social/og-image.jpg',
  ogType = 'website',
  publishedTime,
  author = 'Marcin Ołdak',
  tags = [],
  includeOrganizationSchema = false,
  lang = 'pl',
} = Astro.props;

const siteURL = 'https://www.mjoldak.pl';
const canonicalURL = canonical ?? new URL(Astro.url.pathname, siteURL).toString();
const ogImageURL = ogImage.startsWith('http') ? ogImage : `${siteURL}${ogImage}`;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'MJ.OLDAK',
  legalName: 'MJ.OLDAK SYSTEMS',
  url: siteURL,
  logo: `${siteURL}/favicon.svg`,
  description: 'Budowa agentów AI i automatyzacja procesów dla polskich MŚP — głównie biur rachunkowych.',
  founder: { '@type': 'Person', name: 'Marcin Ołdak' },
  foundingDate: '2026',
  areaServed: { '@type': 'Country', name: 'Polska' },
  knowsAbout: [
    'Agenci AI',
    'Automatyzacja procesów biznesowych',
    'OCR faktur',
    'Claude API',
    'n8n workflow automation',
    'Azure Document Intelligence',
    'AI dla biur rachunkowych',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'biuro@mjoldak.pl',
    contactType: 'sales',
    areaServed: 'PL',
    availableLanguage: ['Polish', 'English'],
  },
  sameAs: [
    'https://www.linkedin.com/in/marcin-oldak',
    'https://github.com/martin0ne',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  url: siteURL,
  name: 'MJ.OLDAK',
  inLanguage: 'pl-PL',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteURL}/artykuly/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- Zero-flash: ustaw zapisany motyw + rozmiar tekstu przed renderem (A−/A+ i dark/light). -->
  <script is:inline>
    (function () {
      try {
        var m = [100, 110, 120, 130];
        var i = parseInt(localStorage.getItem('mjo-text-scale') || '0', 10);
        if (!isNaN(i) && m[i]) document.documentElement.style.fontSize = m[i] + '%';
        var t = localStorage.getItem('mjo-theme');
        if (t === 'dark' || (!t && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      } catch (e) {}
    })();
  </script>
  <meta name="description" content={description} />
  <meta name="author" content={author} />
  <meta name="theme-color" content="#0D1B32" />

  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:locale" content="pl_PL" />
  <meta property="og:site_name" content="MJ.OLDAK" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {ogType === 'article' && <meta property="article:author" content={author} />}
  {tags.map((tag) => <meta property="article:tag" content={tag} />)}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <!-- Self-hosted brand fonts (v2.1 8.05.2026, reflex #20 — NIE Google Fonts CDN). -->
  <!-- @font-face declared in src/styles/global.css; preload top-priority fonts here. -->
  <link rel="preload" as="font" type="font/ttf" crossorigin href="/fonts/Manrope.ttf" />
  <link rel="preload" as="font" type="font/ttf" crossorigin href="/fonts/Inter.ttf" />
  <title>{title}</title>

  {includeOrganizationSchema && (
    <>
      <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
      <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    </>
  )}

  <slot name="head" />
</head>
<body class="bg-background dark:bg-[var(--c-page)] text-dark dark:text-[var(--c-ink)] font-sans m-0 p-0 overflow-x-hidden min-h-[100dvh] flex flex-col transition-colors duration-500">
  <slot />
  <AccessibilityControls client:load />
</body>
</html>
