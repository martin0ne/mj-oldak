---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.jsx';
import Footer from '../../components/Footer.jsx';
import ArticlesBrowser from '../../components/ArticlesBrowser.jsx';
import ArticleCarouselWrapper from '../../components/ArticleCarouselWrapper.astro';
import { TAGS } from '../../content.config';

const all = await getCollection('articles', ({ data }) => !data.draft && data.publishedAt <= new Date());
const articles = all
  .map((a) => ({
    slug: a.id.replace(/\.md$/, ''),
    title: a.data.title,
    excerpt: a.data.excerpt,
    publishedAt: a.data.publishedAt.toISOString(),
    publishedDateLabel: new Intl.DateTimeFormat('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' }).format(a.data.publishedAt),
    category: a.data.category,
    tags: a.data.tags,
    cover: a.data.cover ?? null,
    coverAlt: a.data.coverAlt ?? a.data.title,
    readingTime: a.data.readingTime ?? null,
    featured: a.data.featured,
  }))
  .sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());
---
<BaseLayout
  title="Artykuły — MJ.OLDAK"
  description="Praktyczna wiedza o agentach AI, automatyzacji i wdrożeniach AI w polskich firmach. Case studies, tutoriale, analiza rynku."
>
  <div class="noise-overlay"></div>
  <Navbar client:load />

  <div class="pt-28 md:pt-32">
    {articles.length === 0 ? (
      <section class="px-6 md:px-12 max-w-7xl mx-auto py-20">
        <div class="rounded-[2rem] bg-dark/[0.05] border border-dark/10 p-12 text-center">
          <p class="font-mono text-sm text-dark/60">Pierwsze artykuły w drodze. Zapisz się na newsletter, żeby nie przegapić.</p>
        </div>
      </section>
    ) : (
      <>
        <ArticleCarouselWrapper
          heading="Praktyczna wiedza."
          subheading="AI dla polskich firm bez ściemy. Case studies z biur rachunkowych, koszty wdrożeń, compliance, demo techniczne."
          sectionLabel="[ 05 / ARTYKUŁY ]"
          count={5}
        />

        <section class="px-6 md:px-12 max-w-7xl mx-auto pb-32">
          <div class="mb-10 md:mb-14">
            <span class="font-sans font-medium text-xs uppercase tracking-[0.2em] text-dark/50">[ Wszystkie ]</span>
            <h2 class="font-sans font-bold text-3xl md:text-4xl uppercase tracking-tight text-dark mt-3 leading-tight">
              Pełna <span class="font-serif italic font-normal text-accent">biblioteka.</span>
            </h2>
          </div>
          <ArticlesBrowser
            client:load
            articles={articles}
            allTags={[...TAGS]}
          />
        </section>
      </>
    )}
  </div>

  <Footer client:visible />
</BaseLayout>
