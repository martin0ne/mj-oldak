---
// ContactSection.astro — replika sekcji 07 KONTAKT z home (sea-blue dark style)
// Używany na /artykuly/ + single article pages zamiast generic Footer.jsx
---

<section class="contact" id="contact">
  <iframe class="shader-bg" src="/shaders/grid.html" loading="lazy" title="Operating grid shader"></iframe>
  <div class="container">
    <div class="eyebrow">07 — kontakt</div>
    <h2>Pisz, dzwoń,<br>spotykajmy się.</h2>

    <div class="contact-split">
      <form class="pilot-form contact-form" onsubmit="event.preventDefault(); window.location.href='mailto:biuro@mjoldak.pl?subject=' + encodeURIComponent('Kontakt z mjoldak.pl') + '&body=' + encodeURIComponent((this.elements[0].value ? 'Imię: ' + this.elements[0].value + '\n' : '') + (this.elements[1].value ? 'Email: ' + this.elements[1].value + '\n\n' : '') + (this.elements[2].value || ''));">
        <label>Imię i biuro</label>
        <input type="text" placeholder="Anna Kowalska, Biuro Rachunkowe XYZ" />
        <label>Email</label>
        <input type="email" placeholder="anna@biuro.pl" />
        <label>O czym chcesz pogadać (1 zdanie)</label>
        <textarea rows="3" placeholder="Np. szukamy konsultacji w sprawie OCR faktur..."></textarea>
        <button type="submit" class="cta" style="margin-top: 12px; width: 100%; justify-content: center; border: 0;">Wyślij wiadomość →</button>
      </form>

      <div class="contact-info">
        <div class="contact-grid">
          <div>
            <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="M3 7l9 6 9-6"/>
            </svg>
            <h4>Email</h4>
            <a href="mailto:biuro@mjoldak.pl">biuro@mjoldak.pl</a>
          </div>
          <div>
            <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="3"/>
              <path d="M7 10v7"/>
              <circle cx="7" cy="7" r="0.8" fill="currentColor"/>
              <path d="M11 17v-4a3 3 0 016 0v4"/>
              <path d="M11 17v-7"/>
            </svg>
            <h4>Linkedin</h4>
            <a href="https://www.linkedin.com/in/mjoldak" target="_blank" rel="noopener">linkedin.com/in/mjoldak</a>
          </div>
          <div>
            <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="9"/>
              <path d="M3 12h18"/>
              <path d="M12 3a14 14 0 010 18"/>
              <path d="M12 3a14 14 0 000 18"/>
            </svg>
            <h4>Strona WWW</h4>
            <a href="https://www.mjoldak.pl" target="_blank" rel="noopener">www.mjoldak.pl</a>
          </div>
          <div>
            <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5.5 9.5a6.5 6.5 0 0113 0c0 4.7-6.5 11-6.5 11s-6.5-6.3-6.5-11z"/>
              <circle cx="12" cy="9.5" r="2.5"/>
            </svg>
            <h4>Lokalizacja</h4>
            Wrocław, PL<br>+ wdrożenia zdalne w całej Polsce
          </div>
          <div>
            <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 4h4l2 5-2.5 1.5a11 11 0 005 5L15 13l5 2v4a2 2 0 01-2 2A15 15 0 013 6a2 2 0 012-2z"/>
            </svg>
            <h4>Telefon</h4>
            <span class="placeholder">numer firmowy &mdash; wkrótce</span>
          </div>
        </div>
      </div>
    </div>

    <div class="footer-bar">
      <span>MJ.OLDAK · 2026 · <a href="https://www.mjoldak.pl" target="_blank" rel="noopener" style="border-bottom: 1px dotted currentColor;">www.mjoldak.pl</a></span>
      <span>biuro@mjoldak.pl</span>
    </div>
  </div>
</section>

<style>
  :root {
    --accent-cs: #4F8EBA;
    --dark-cs: #0D1B32;
  }
  .contact {
    background: var(--dark-cs); color: #fff; padding: 120px 64px 40px;
    display: flex; flex-direction: column; justify-content: flex-start;
    position: relative; overflow: hidden;
    text-shadow: 0 1px 3px rgba(13,27,50,0.5);
  }
  .contact .shader-bg {
    position: absolute; inset: 0; z-index: 0;
    width: 100%; height: 100%;
    border: 0; pointer-events: none;
    opacity: 0.7;
  }
  .contact::before {
    content: ''; position: absolute; inset: 0; z-index: 1;
    pointer-events: none;
    background: radial-gradient(ellipse at 50% 40%,
      color-mix(in srgb, var(--dark-cs) 25%, transparent) 0%,
      color-mix(in srgb, var(--dark-cs) 10%, transparent) 60%,
      transparent 100%);
  }
  .contact .container { position: relative; z-index: 2; max-width: 1280px; margin: 0 auto; }
  .contact .eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.25em; text-transform: uppercase;
    opacity: 0.85; margin-bottom: 24px;
    display: inline-block;
  }
  .contact h2 {
    font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 48px;
    letter-spacing: -0.025em; line-height: 1.05;
    margin: 0 0 28px 0;
  }
  .contact-split {
    display: grid; grid-template-columns: 1.1fr 1fr; gap: 56px; margin-top: 32px;
    margin-bottom: 56px; align-items: start;
  }
  .pilot-form {
    background: rgba(0,0,0,0.4); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 28px; padding: 32px;
  }
  .pilot-form label {
    display: block; font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.6; margin-bottom: 6px;
  }
  .pilot-form input, .pilot-form textarea {
    width: 100%; padding: 12px 14px; margin-bottom: 16px;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.14);
    border-radius: 12px; color: #fff;
    font-family: 'Inter', sans-serif; font-size: 15px;
    box-sizing: border-box;
  }
  .pilot-form input:focus, .pilot-form textarea:focus {
    outline: none; border-color: var(--accent-cs);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent-cs) 25%, transparent);
  }
  .contact-info { display: flex; flex-direction: column; gap: 24px; color: #fff; }
  .contact-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;
  }
  .contact-grid > div {
    padding-left: 0;
    font-family: 'Inter', sans-serif; font-size: 14px; line-height: 1.7;
  }
  .contact-grid .ico {
    width: 28px; height: 28px;
    color: var(--accent-cs);
    transition: color 0.6s ease, transform 0.3s;
    margin-bottom: 14px; display: block;
  }
  .contact-grid > div:hover .ico { transform: translateY(-2px); }
  .contact-grid h4 {
    font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em;
    text-transform: uppercase; opacity: 0.5; margin: 0 0 12px 0;
  }
  .contact-grid a { color: #fff; text-decoration: none; transition: color 0.3s; }
  .contact-grid a:hover { color: var(--accent-cs); }
  .contact-grid .placeholder {
    opacity: 0.45; font-style: italic;
  }
  .cta {
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    background: var(--accent-cs); color: #fff;
    padding: 16px 32px; border-radius: 999px;
    font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 14px; letter-spacing: 0.02em;
    box-shadow: 0 8px 32px color-mix(in srgb, var(--accent-cs) 50%, transparent);
    transition: background 0.6s ease, box-shadow 0.6s ease, transform 0.2s, color 0.2s;
    border: 2px solid transparent; cursor: pointer;
  }
  .cta:hover { background: #fff; color: var(--dark-cs); transform: translateY(-2px); border-color: var(--accent-cs); }
  .footer-bar {
    border-top: 1px solid rgba(255,255,255,0.12);
    padding-top: 24px; position: relative; z-index: 2;
    display: flex; justify-content: space-between; opacity: 0.6;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: #fff;
  }
  .footer-bar a { color: #fff; text-decoration: none; }
  @media (max-width: 900px) {
    .contact { padding: 80px 24px 32px; }
    .contact h2 { font-size: 32px; }
    .contact-split { grid-template-columns: 1fr; gap: 32px; }
    .footer-bar { flex-direction: column; gap: 8px; }
  }
</style>
